{
  "name": "hyphen-ops-backend",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build && concurrently -k -n API-BUILD,API -c yellow,cyan \"npm:dev:build\" \"npm:dev:run\"",
    "dev:build": "tsc -p server/tsconfig.json --watch --preserveWatchOutput",
    "dev:run": "node --watch server/dist/main.js",
    "build": "tsc -p server/tsconfig.json",
    "start": "node server/dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/platform-fastify": "^11.1.13",
    "@prisma/client": "^6.16.2",
    "date-fns": "^4.1.0",
    "fastify": "^5.7.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "concurrently": "^9.2.1",
    "prisma": "^6.16.2",
    "typescript": "~5.9.3"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
